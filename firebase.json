{
  "functions": [
    {
      "codebase": "eventvault-func",
      "source": "eventvault-func",
      "ignore": [
        "node_modules",
        ".git",
        "firebase-debug.log",
        "firebase-debug.*.log"
      ]
    }
  ],
  "hosting": {
    "public": "public",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "/api/**",
        "function": "api"
      },
      {
        "source": "/choice/**",
        "destination": "/choice.html"
      },
      {
        "source": "/signup/**",
        "destination": "/signup.html"
      },
      {
        "source": "/user-login",
        "destination": "/user-login.html"
      },
      {
        "source": "/user-signup",
        "destination": "/user-signup.html"
      },
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  },
  "firestore": {
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "dataconnect": {
    "source": "dataconnect"
  }
}
